{
  "name": "orset-rdf-store",
  "version": "0.0.0",
  "packageManager": "yarn@1.22.22+sha512.a6b2f7906b721bba3d67d4aff083df04dad64c399707841b7acf00f6b133b7ac24255f2652fa22ae3534329dc6180534e98d17432037ff6fd140556e2bb3137e",
  "description": "A proof-of-concept RDFjs-compliant triple store with state-based OR-Set (add-wins) CRDT semantics, enabling conflict-free concurrent writes to RDF datasets over HTTP",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/jitsedesmet/add-wins-OR-set-RDF-datastore"
  },
  "bugs": {
    "url": "https://github.com/jitsedesmet/add-wins-OR-set-RDF-datastore/issues"
  },
  "keywords": [
    "rdf",
    "rdfjs",
    "crdt",
    "or-set",
    "conflict-free",
    "offline-first",
    "rdf-1.2",
    "triple-store",
    "eventual-consistency"
  ],
  "sideEffects": false,
  "main": "lib/index.js",
  "typings": "lib/index",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "lib/**/*.d.ts",
    "lib/**/*.js",
    "lib/**/*.js.map"
  ],
  "scripts": {
    "build": "yarn run build:ts",
    "build:ts": "node \"node_modules/typescript/bin/tsc\"",
    "clean": "git clean -dfx",
    "test": "jest",
    "lint": "eslint . --cache",
    "lint-fix": "eslint . --fix",
    "postinstall": "yarn husky && yarn run build"
  },
  "dependencies": {
    "@comunica/utils-expression-evaluator": "^5.1.3",
    "asynciterator": "^3.10.0",
    "n3": "2.0.0-beta.2",
    "rdf-stores": "^2.2.0"
  },
  "devDependencies": {
    "@comunica/query-sparql": "^5.1.3",
    "@comunica/types": "^5.1.3",
    "@jest/types": "^30.3.0",
    "@playwright/test": "^1.47.2",
    "@rdfjs/types": "^2.0.1",
    "@rubensworks/eslint-config": "^3.1.0",
    "@types/etag": "^1.8.4",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/n3": "^1.26.1",
    "@types/node": "^24.10.0",
    "depcheck": "^1.4.3",
    "eslint": "^8.57.0",
    "etag": "^1.8.1",
    "express": "^5.2.1",
    "husky": "^9.0.0",
    "jest": "^29.5.0",
    "rdf-data-factory": "^2.0.2",
    "ts-jest": "^29.0.5",
    "ts-node": "^10.0.0",
    "typescript": "^5.9.3"
  }
}
